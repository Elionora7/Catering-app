# Database
DATABASE_URL="postgresql://user:password@localhost:5432/catering_app?schema=public"
# Hosted Postgres (Neon, etc.): add `sslmode=verify-full` to the URL query string in Vercel to match future pg
# behaviour and remove the "SSL modes prefer/require/verify-ca are treated as aliases" warning in logs.

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"
# Set to "true" only when debugging NextAuth (enables verbose logs)
# NEXTAUTH_DEBUG="true"

# Node Environment
NODE_ENV="development"
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Email / SMTP (STARTTLS, port 587 — see lib/mailer/createSmtpTransport.ts)
# SMTP_HOST=mail.eliorasignaturecatering.com.au
# SMTP_PORT=587
# SMTP_USER=info@eliorasignaturecatering.com.au
# SMTP_PASS=your_mailbox_password
# SMTP_ALLOW_SELF_SIGNED=false
# SMTP_REQUIRE_TLS=true
# QUOTE_NOTIFY_EMAIL=info@eliorasignaturecatering.com.au
# Full sender (quoted in Vercel so spaces are kept):
# EMAIL_FROM="Eliora Quotes <info@eliorasignaturecatering.com.au>"
# If unquoted, only the first word is kept — set display name separately:
# EMAIL_FROM_NAME=Eliora Quotes
# Business copy of order confirmations (Gmail or shared inbox)
# ORDER_NOTIFY_EMAIL=fgfk@gmail.com
# Copy into your host env UI for production (do not commit real secrets).




